{
  "name": "mssql-mcp-server",
  "version": "0.6.0",
  "description": "Model Context Protocol server for Microsoft SQL Server with multi-instance support.",
  "type": "module",
  "bin": {
    "mssql-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "config.example.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:plugin": "node scripts/build-plugin.mjs",
    "build:mcpb": "node scripts/build-mcpb.mjs",
    "build:bundles": "npm run build && npm run build:plugin && npm run build:mcpb",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "tsc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "mssql": "^11.0.1",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/mssql": "^9.1.7",
    "@types/node": "^22.7.0",
    "adm-zip": "^0.5.17",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mssql",
    "sql-server",
    "claude"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bherbruck/mssql-mcp-server.git"
  },
  "optionalDependencies": {
    "msnodesqlv8": "^5.2.0"
  }
}
